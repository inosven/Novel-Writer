{
  "name": "novel-writer",
  "version": "1.0.0",
  "description": "AI-powered novel writing agent system",
  "main": "dist-electron/main.js",
  "type": "module",
  "bin": {
    "novelwriter": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "vite",
    "dev:cli": "tsx watch src/index.ts",
    "build": "vite build",
    "build:tsc": "tsc",
    "preview": "vite preview",
    "cli": "tsx src/cli.ts",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux",
    "package": "npm run electron:build",
    "test": "vitest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@lancedb/lancedb": "^0.13.0",
    "@tanstack/react-query": "^5.90.19",
    "apache-arrow": "^21.1.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "electron-store": "^11.0.2",
    "epub2": "^3.0.2",
    "eventemitter3": "^5.0.1",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "inquirer": "^12.1.0",
    "marked": "^15.0.4",
    "ollama": "^0.5.11",
    "openai": "^4.73.0",
    "ora": "^8.1.1",
    "p-queue": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0",
    "uuid": "^10.0.0",
    "winston": "^3.17.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.14.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.5",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
